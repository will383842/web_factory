includes:
    - vendor/larastan/larastan/extension.neon
    - phpstan-baseline.neon

parameters:
    level: 8
    paths:
        - app
        - tests
        - database/seeders
    excludePaths:
        - app/Filament/Resources/*/Pages/*
        - bootstrap/cache/*

    checkOctaneCompatibility: true
    # checkModelProperties: true was disabled in Sprint 13.4 — it requires
    # every DB column to be mirrored as a @property docblock on its Eloquent
    # model, which is non-standard in Laravel apps and produced 230+ false
    # positives across legacy tests + new BCs. The arch tests already enforce
    # that Eloquent stays inside Infrastructure, which is the meaningful guard.
    noUnnecessaryCollectionCall: true
    noUnnecessaryCollectionCallOnly: []
    noUnnecessaryCollectionCallExcept: []

    ignoreErrors:
        # Pest test files use the global "test()" / "it()" / "expect()" helpers
        - identifier: missingType.parameter
          paths:
            - tests/*
        # arch() helper and Pest dynamic API (TestCall->expect/preset/get/...)
        - '#Call to an undefined (method|static method) Pest\\.*#'
        # Pest dynamic Laravel test methods ($this->get, $this->post, ...) on TestCall
        - '#Call to an undefined method Pest\\PendingCalls\\TestCall::.*#'
        # Pest test files use $this->propName set in beforeEach() — dynamic assignment
        - '#Access to an undefined property Pest\\PendingCalls\\TestCall::\$.*#'
        # Pest expectation chain $not is a magic method/property
        - '#Access to an undefined property Pest\\Mixins\\Expectation.*::\$not.#'
        # Pest expect()->and() generic resolution noise — Pest infers TValue
        # via reflection on each chain step, which PHPStan cannot statically
        # follow. Runtime is correct.
        - '#Unable to resolve the template type T(And)?Value in call to (function expect|method Pest\\Expectation<.+>::and\(\))#'
        # In tests we factory()->create() then access properties; PHPStan still sees |null|Collection
        - identifier: property.nonObject
          path: tests/*
        - identifier: method.nonObject
          path: tests/*
        # Trivial Laravel default test
        - identifier: method.alreadyNarrowedType
          path: tests/Unit/ExampleTest.php
        # Seeder $this->command is nullable at runtime in Laravel (set only via artisan)
        - '#Using nullsafe method call on non-nullable type Illuminate\\Console\\Command\.#'
        # env() is legitimate in seeders for local dev credentials
        - identifier: larastan.noEnvCallsOutsideOfConfig
          path: database/seeders/*
        # request() returns a real Request via container in HTTP context, null in CLI/queue;
        # nullsafe is intentional defensive coding
        - '#Using nullsafe method call on non-nullable type Illuminate\\Http\\Request\.#'
        # Telescope default gate has an empty allowlist that we fill at deploy time
        - identifier: function.impossibleType
          path: app/Providers/TelescopeServiceProvider.php
        # Spatie Permission's Eloquent Builder->pluck() typedef wants Expression — strings are fine at runtime
        - identifier: argument.type
          path: tests/Feature/Identity/RolePermissionTest.php
        # BelongsTo template covariance noise — Larastan upstream open issue:
        # `$this(Model)` vs Model in BelongsTo<TParent, TDeclaringModel> generic
        - '#Method App\\Models\\.+::\w+\(\) should return Illuminate\\Database\\Eloquent\\Relations\\BelongsTo<.+> but returns Illuminate\\Database\\Eloquent\\Relations\\BelongsTo<.+>\.#'
        # Same template covariance issue applies to HasMany (Sprint 13.1+).
        - '#Method App\\Models\\.+::\w+\(\) should return Illuminate\\Database\\Eloquent\\Relations\\HasMany<.+> but returns Illuminate\\Database\\Eloquent\\Relations\\HasMany<.+>\.#'
        # Same template covariance issue applies to BelongsToMany (Sprint 13.2+).
        - '#Method App\\Models\\.+::\w+\(\) should return Illuminate\\Database\\Eloquent\\Relations\\BelongsToMany<.+> but returns Illuminate\\Database\\Eloquent\\Relations\\BelongsToMany<.+>\.#'
        # Larastan's Eloquent property auto-discovery is unreliable when our
        # models live under App\Models but the migrations live under
        # database/migrations/ (the model class doesn't @property-annotate
        # every column). The runtime correctness is enforced by Pest tests
        # (RefreshDatabase + assertions), and the arch tests guarantee
        # Eloquent stays inside Infrastructure boundaries — the upside of
        # turning these errors into red is not worth annotating ~80 columns.
        - '#Access to an undefined property App\\Models\\.+::\$.+#'
        # JsonResource @mixin chain inherits the same model-property gap.
        - '#Access to an undefined property App\\Http\\Resources\\.+::\$.+#'
        # Sanctum personal_access_tokens "token" column not typed in the
        # PersonalAccessToken model stub — accept literal "token" string here.
        - identifier: argument.type
          path: app/Http/Controllers/Api/V1/Auth/TwoFactorController.php

    reportUnmatchedIgnoredErrors: false
    treatPhpDocTypesAsCertain: false
