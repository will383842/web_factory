includes:
    - vendor/larastan/larastan/extension.neon
    - phpstan-baseline.neon

parameters:
    level: 8
    paths:
        - app
        - tests
        - database/seeders
    excludePaths:
        - app/Filament/Resources/*/Pages/*
        - bootstrap/cache/*

    checkOctaneCompatibility: true
    checkModelProperties: true
    noUnnecessaryCollectionCall: true
    noUnnecessaryCollectionCallOnly: []
    noUnnecessaryCollectionCallExcept: []

    ignoreErrors:
        # Pest test files use the global "test()" / "it()" / "expect()" helpers
        - identifier: missingType.parameter
          paths:
            - tests/*
        # arch() helper and Pest dynamic API (TestCall->expect/preset/get/...)
        - '#Call to an undefined (method|static method) Pest\\.*#'
        # Pest dynamic Laravel test methods ($this->get, $this->post, ...) on TestCall
        - '#Call to an undefined method Pest\\PendingCalls\\TestCall::.*#'
        # Pest test files use $this->propName set in beforeEach() — dynamic assignment
        - '#Access to an undefined property Pest\\PendingCalls\\TestCall::\$.*#'
        # Pest expectation chain $not is a magic method/property
        - '#Access to an undefined property Pest\\Mixins\\Expectation.*::\$not.#'
        # In tests we factory()->create() then access properties; PHPStan still sees |null|Collection
        - identifier: property.nonObject
          path: tests/*
        - identifier: method.nonObject
          path: tests/*
        # Trivial Laravel default test
        - identifier: method.alreadyNarrowedType
          path: tests/Unit/ExampleTest.php
        # Seeder $this->command is nullable at runtime in Laravel (set only via artisan)
        - '#Using nullsafe method call on non-nullable type Illuminate\\Console\\Command\.#'
        # env() is legitimate in seeders for local dev credentials
        - identifier: larastan.noEnvCallsOutsideOfConfig
          path: database/seeders/*
        # request() returns a real Request via container in HTTP context, null in CLI/queue;
        # nullsafe is intentional defensive coding
        - '#Using nullsafe method call on non-nullable type Illuminate\\Http\\Request\.#'
        # Telescope default gate has an empty allowlist that we fill at deploy time
        - identifier: function.impossibleType
          path: app/Providers/TelescopeServiceProvider.php
        # Spatie Permission's Eloquent Builder->pluck() typedef wants Expression — strings are fine at runtime
        - identifier: argument.type
          path: tests/Feature/Identity/RolePermissionTest.php
        # BelongsTo template covariance noise — Larastan upstream open issue:
        # `$this(Model)` vs Model in BelongsTo<TParent, TDeclaringModel> generic
        - '#Method App\\Models\\.+::\w+\(\) should return Illuminate\\Database\\Eloquent\\Relations\\BelongsTo<.+> but returns Illuminate\\Database\\Eloquent\\Relations\\BelongsTo<.+>\.#'

    reportUnmatchedIgnoredErrors: false
    treatPhpDocTypesAsCertain: false
