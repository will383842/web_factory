APP_NAME=WebFactory
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

# Sessions / cookies (must match APP_URL host for Filament login to work)
SESSION_DOMAIN=localhost
SESSION_SECURE_COOKIE=false
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Database (PostgreSQL 16 in wf-postgres container)
DB_CONNECTION=pgsql
DB_HOST=wf-postgres
DB_PORT=5432
DB_DATABASE=webfactory
DB_USERNAME=webfactory
DB_PASSWORD=secret

# Redis - 2 separate instances
REDIS_CLIENT=predis

# Cache instance
REDIS_HOST=wf-redis-cache
REDIS_PORT=6379
REDIS_PASSWORD=null

# Sessions instance (separate, persistent)
REDIS_SESSION_HOST=wf-redis-sessions
REDIS_SESSION_PORT=6379
REDIS_SESSION_PASSWORD=null

CACHE_STORE=redis
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=reverb

# Mail (mailhog/log in dev, real SMTP in prod)
MAIL_MAILER=log
MAIL_FROM_ADDRESS=no-reply@webfactory.local
MAIL_FROM_NAME="${APP_NAME}"

# Filesystem (S3-compatible MinIO in dev)
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=webfactory
AWS_SECRET_ACCESS_KEY=secret_change_me_local_only
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=webfactory
AWS_ENDPOINT=http://wf-minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

# Meilisearch
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://wf-meili:7700
MEILISEARCH_KEY=local_dev_master_key_change_me
MEILI_ENV=development

# Reverb (WebSocket)
REVERB_APP_ID=webfactory
REVERB_APP_KEY=local
REVERB_APP_SECRET=local_change_me
REVERB_HOST=wf-reverb
REVERB_PORT=8080
REVERB_SCHEME=http

# Sentry (placeholder - leave empty to disable)
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0

# Telescope (only in local)
TELESCOPE_ENABLED=true

# Logging
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Filament admin local seeder credentials (override in your local .env)
ADMIN_EMAIL=admin@webfactory.local
ADMIN_PASSWORD=please-change-me

# Vite (dev server)
VITE_APP_NAME="${APP_NAME}"
