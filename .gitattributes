# Default: text files normalized to LF in repo, working dir uses platform native eol on checkout
* text=auto eol=lf

# Windows-only scripts: keep CRLF
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Binary files - never normalize
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       binary -text=auto
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.pdf       binary
*.zip       binary
*.tar.gz    binary

# Force LF on shell scripts (entrypoints) - required for Docker Linux containers
*.sh        text eol=lf

# Diff: language hints
*.php       text eol=lf diff=php
*.md        text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.css       text eol=lf
*.ts        text eol=lf
*.vue       text eol=lf
*.blade.php text eol=lf

# Don't export unnecessary files when archiving
.gitattributes  export-ignore
.gitignore      export-ignore
tests           export-ignore
docs            export-ignore
.github         export-ignore
docker          export-ignore
phpstan.neon    export-ignore
