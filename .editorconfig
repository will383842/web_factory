root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml,json,vue,ts,js,css,html}]
indent_size = 2

[*.{cmd,bat,ps1}]
end_of_line = crlf

[Makefile]
indent_style = tab
